# Copy to .env and fill in. Never commit real secrets.

# Postgres (orchestrator state of record + event bus)
DATABASE_URL=postgres://devspace:devspace@localhost:5432/devspace

# Service ports
ORCHESTRATOR_PORT=4000
SANDBOX_CORE_PORT=4001
CHAT_GATEWAY_PORT=4002
AGENT_RUNNER_PORT=4003

# Slack adapter (M4, primary surface) — Socket Mode, so no public URL needed.
# Create the app by pasting infra/slack/manifest.yaml (instructions inside).
# Live runs are local-only: restricted egress (remote CI/dev containers) blocks
# slack.com, and the live itest self-skips when these are unset.
SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=

# Discord adapter (M6). chat-gateway-svc runs ONE platform per process:
# CHAT_PLATFORM=slack (default) or discord.
CHAT_PLATFORM=
DISCORD_TOKEN=
DISCORD_APPLICATION_ID=

# Two-service split (M6, m6-plan A). All unset = the M4 in-process demo
# (chat-gateway boots the orchestrator itself). To run the real split:
#  - both services: a shared random bearer token (openssl rand -hex 32)
#  - chat-gateway-svc: ORCHESTRATOR_URL=http://orchestrator:4000 (no DB needed)
#  - orchestrator-svc: GATEWAY_RENDER_URL=http://chat-gateway:4002/render
# The internal API is disabled entirely while the token is unset.
DEVSPACE_INTERNAL_TOKEN=
ORCHESTRATOR_URL=
GATEWAY_RENDER_URL=

# Secret store envelope keyring (M3) — host keys kept OUT of the database.
# Format: "<keyId>:<base64 32-byte key>". This is the CURRENT write key.
# Generate one with:  node -e 'console.log("k1:"+require("crypto").randomBytes(32).toString("base64"))'
SECRET_ENVELOPE_KEY=
# Optional retired keys (decrypt-only during rotation), comma-separated same format.
SECRET_ENVELOPE_KEYS_RETIRED=

# GitHub REST base (override for GitHub Enterprise / on-prem)
GITHUB_API_BASE=https://api.github.com
# GitHub webhook ingress (M5) — the PR source of truth when set. Configure a
# repo/org webhook for `pull_request` events pointing at
# POST /webhooks/github with this shared secret. Unset = ingress disabled.
GITHUB_WEBHOOK_SECRET=
# PR poll reconciler interval, milliseconds. Since M5 the poll is the drift
# backstop for webhooks; defaults to 300000 with webhooks configured, 30000
# without. Since M15 the poll runs on ONE controller: the holder of the
# pr-reconciler lease (TTL 2x this interval; clean shutdowns hand over
# immediately).
RECONCILE_INTERVAL_MS=
# Multi-controller (M14/M15): names this instance in bus-claim diagnostics
# and the reconciler lease. Unset: a per-boot random id.
DEVSPACE_INSTANCE_ID=
# Rolling-deploy handover (M15): 1/true leaves still-unclaimed warm-pool
# stock alive on clean shutdown (pool-marked on the host, so sibling
# controllers or the next boot adopt it). Unset/0: destroy on stop (M9).
SANDBOX_WARM_KEEP_ON_STOP=
# Fleet utilization sampling (M16), fleet mode only: poll each sandbox host's
# GET /stats every N ms and let placement RANKING weigh fresh measured heat
# alongside grants (admission stays grant-based). Unset/0: off — pure M12
# grant ranking.
SANDBOX_STATS_INTERVAL_MS=
# Lifecycle reclamation (M17). Both unset = no reaper (nothing is ever torn
# down automatically — the pre-M17 posture). Runs on ONE controller: the
# holder of the lifecycle-reaper lease (TTL 2x the interval).
# Tear down a pre-PR session whose user has been silent this long (PR_OPEN
# is exempt: GitHub owns that lifecycle). Announced in the thread.
DEVSPACE_IDLE_TTL_MS=
# Warn the thread this long before the idle TTL reaps it (M18). With this
# set, no idle reap ever happens unwarned — a warning must stand for the
# full window first. Requires DEVSPACE_IDLE_TTL_MS and must be smaller.
DEVSPACE_IDLE_WARN_MS=
# Tear down PR_MERGED / PR_CLOSED / FAILED units unchanged for this long
# (env + secrets cleanup; the conversation and audit rows survive).
DEVSPACE_TERMINAL_GRACE_MS=
# Release the ENVIRONMENT of a PR_OPEN unit idle this long (M18): container,
# per-env network, and preview routes go; the unit, its secrets, and the
# merge/close announcement stay — the PR flow is unaffected.
DEVSPACE_PR_OPEN_ENV_TTL_MS=
# Sweep cadence, default 60000. Refused if set with no TTL above.
DEVSPACE_REAP_INTERVAL_MS=

# Sandbox hardening (M5) — host policy applied to EVERY provisioned env
# (docs/m5-plan.md Decision 1). All unset = plain-Docker demo mode
# (docs/security.md: demo only; never multi-tenant).
# SANDBOX_HARDENED=1 enables the hardened defaults: gVisor (runsc),
# no-new-privileges, cap-drop ALL + minimal add-back, per-env --internal network.
SANDBOX_HARDENED=
# Override the runtime class ('runsc', 'kata-runtime'; empty = plain runc).
# Boot fails fast if the configured runtime is missing from the daemon.
SANDBOX_RUNTIME=
# 'per-env' (isolated --internal network per env) or a named docker network.
SANDBOX_NETWORK=
# Opt-in disk quota via --storage-opt (requires overlay2 on xfs+pquota).
SANDBOX_DISK_QUOTA=
# Egress allowlist proxy (the only door out of an --internal env network).
# Port for the in-process proxy + per-env gateway resolution:
EGRESS_PROXY_PORT=
# ...or a static proxy URL for fixed/named-network deployments:
EGRESS_PROXY_URL=
# Extra allowlisted hosts beyond the defaults (github/LLM/npm), comma-separated.
# Exact hostnames or *.suffix wildcards.
EGRESS_ALLOWLIST=

# Ports preview proxy (M6) — authenticated ingress to env ports. Off when
# PREVIEW_PROXY_PORT is unset (forwardPort rejects with a clear message).
# PREVIEW_BASE_URL is the public scheme://host[:port] users can reach (TLS /
# hostname termination happens in front); defaults to the bind address.
PREVIEW_PROXY_PORT=
PREVIEW_BIND_HOST=
PREVIEW_BASE_URL=

# LLM access for the agent (M2/M6). Stored per-conversation as LLM_KEY (in-chat
# via the Slack set-secrets modal since M6) and injected per-exec: codex reads
# OPENAI_API_KEY, the claude backend reads ANTHROPIC_API_KEY.
LLM_API_KEY=
