# E2E 시나리오 실행 설정 — .env.e2e 로 복사해서 채우세요. (자세한 설명: docs/decisions.md)

# 테스트 대상 devspace 서버 주소
DEVSPACE_URL=http://localhost:3000

# 시나리오가 클론하고 PR을 만드는 테스트 전용 레포 (owner/name).
# 실제 프로젝트 레포를 쓰지 말 것 — PR 생성/삭제가 자유로운 전용 레포를 하나 만든다.
E2E_REPO=agentwiki/devspace-e2e-playground

# 위 테스트 레포에만 contents/pull-requests 쓰기 권한이 있는 fine-grained PAT
E2E_GITHUB_TOKEN=
