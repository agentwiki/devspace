// Persistence schema for the on-prem agent platform.
// The orchestrator is the only writer of work-unit state.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Conversation {
  id                String     @id @default(cuid())
  platform          String // discord | slack | web
  externalChannelId String
  userId            String
  createdAt         DateTime   @default(now())
  workUnits         WorkUnit[]

  @@unique([platform, externalChannelId])
  @@map("conversations")
}

// One unit of work per conversation tracked through the GitHub work cycle.
model WorkUnit {
  id             String       @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id])
  envId          String?
  agentSessionId String?
  // WorkState enum from @devspace/contracts (stored as text for forward-compat).
  state          String       @default("CREATED")
  repoUrl        String?
  branch         String?
  prNumber       Int?
  prUrl          String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([conversationId])
  @@index([state])
  @@map("work_units")
}

// Per-user / per-conversation secrets (GitHub token, LLM key). Ciphertext only.
model Secret {
  id             String   @id @default(cuid())
  userId         String
  conversationId String?
  name           String // e.g. GITHUB_TOKEN, LLM_KEY
  ciphertext     String // envelope-encrypted; plaintext never stored or logged
  keyId          String // which envelope key encrypted this
  createdAt      DateTime @default(now())

  @@unique([userId, conversationId, name])
  @@map("secrets")
}

// Durable event log + LISTEN/NOTIFY backing table (MVP event bus).
model Event {
  id         String   @id @default(cuid())
  topic      String
  workUnitId String?
  payload    Json
  emittedAt  DateTime @default(now())
  consumedAt DateTime?

  @@index([topic])
  @@index([workUnitId])
  @@map("events")
}
